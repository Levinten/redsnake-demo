# ── RedSnake Configuration ─────────────────────────────────────
REDSNAKE_ENV=dev
REDSNAKE_NAME=redsnake

# ── Nginx / Reverse Proxy ─────────────────────────────────────
# For HTTP  (dev):  NGINX_CONF=nginx-http.conf  LISTEN_PORT=80   OUTSIDE_PORT=8080
# For HTTPS (prod): NGINX_CONF=nginx.conf       LISTEN_PORT=443  OUTSIDE_PORT=443
NGINX_CONF=nginx-http.conf
LISTEN_PORT=80
OUTSIDE_PORT=8080
OUTSIDE_FQDN=localhost

# Paths to SSL certs inside userconf/certs/ (only needed for HTTPS)
KEY_FILEPATH=privkey.pem
CERTCHAIN_FILEPATH=fullchain.pem

# ── Flask ──────────────────────────────────────────────────────
# CHANGE THIS to a long random string in production
SECRET_KEY=change-me-in-production

# ── Database (PostgreSQL) ─────────────────────────────────────
POSTGRES_DB=appdb
POSTGRES_USER=app
# CHANGE THIS to a strong password
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://app:change-me@postgres:5432/appdb

# ── Redis & Celery ─────────────────────────────────────────────
# CHANGE THIS to a strong password
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@redis:6379/2
CELERY_BROKER_URL=redis://:change-me@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change-me@redis:6379/1

# ── Gunicorn ───────────────────────────────────────────────────
GUNICORN_WORKERS=3
GUNICORN_THREADS=8

# ── Celery Worker ──────────────────────────────────────────────
CELERY_LOGLEVEL=INFO
CELERY_CONCURRENCY=4

# ── Scripts Git Repository ─────────────────────────────────────
# SSH URL of the repository containing a "scripts/" folder.
# Leave empty to skip automatic cloning.
GIT_REPO_URL=
GIT_BRANCH=main

# ── Paths (usually no need to change) ─────────────────────────
SCRIPTS_DIR=/app/repo/scripts
VAULT_FILE=/app/data/vault.enc
