# ===========================================
# RedSnake - Environment Configuration
# ===========================================

# Encryption secret for sensitive data in the database (Fernet key)
REDSNAKE_SECRET=IMhGOe3QrqEtMJ5KItaHc7gYZZph5wZcShKwdcfsk9U=
REDSNAKE_ENV=prod

# ------ PostgreSQL System DB ------
POSTGRES_SYSTEM_PASSWORD=redsnake_system_pass
SYSTEM_DATABASE_URL=postgresql://redsnake:redsnake_system_pass@redsnake-postgres-system:5432/redsnake_system

# ------ PostgreSQL User DB ------
POSTGRES_USER_PASSWORD=redsnake_user_pass
USER_DATABASE_URL=postgresql://redsnake:redsnake_user_pass@redsnake-postgres-user:5432/redsnake_user

# ------ Redis ------
# DB 0 = Celery broker/backend, DB 1 = App logic
REDIS_URL=redis://redsnake-redis:6379/1
CELERY_BROKER_URL=redis://redsnake-redis:6379/0
CELERY_RESULT_BACKEND=redis://redsnake-redis:6379/0
